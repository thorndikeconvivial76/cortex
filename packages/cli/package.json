{
  "name": "@cortex/cli",
  "version": "1.0.0",
  "description": "Cortex CLI — persistent memory for Claude Code and AI agents",
  "type": "module",
  "bin": {
    "cortex": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "publishConfig": {
    "name": "@cortex-memory/cli",
    "access": "public"
  },
  "author": "K2N2 Studio <koundinya@k2n2studio.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ProductionLineHQ/cortex"
  },
  "homepage": "https://cortex.sh",
  "bugs": {
    "url": "https://github.com/ProductionLineHQ/cortex/issues"
  },
  "keywords": [
    "claude-code",
    "memory",
    "mcp",
    "ai",
    "persistent-memory",
    "cortex"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@cortex/shared": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0"
  }
}
